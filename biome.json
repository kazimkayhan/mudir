{
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "src/**",
      "./*.json",
      "./*.js",
      "./*.ts",
      "./*.mts",
      "./*.mjs",
      "!!dist",
      "!!src-tauri",
      "!!node_modules",
      "!!public/pdf.worker.min.mjs",
      "!!drizzle"
    ]
  },
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next"
  ],
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedAttributes": "on",
        "useSortedKeys": "on",
        "useSortedProperties": "on"
      }
    },
    "enabled": true
  }
}
